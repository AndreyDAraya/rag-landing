---
import Layout from '../layouts/Layout.astro';
---

<Layout title="RAG Engine - IA para tu negocio">
  <div class="fixed inset-0 bg-grid-pattern pointer-events-none"></div>
  <div class="fixed inset-0 bg-dots-pattern pointer-events-none opacity-30"></div>

  <nav class="relative z-50 flex items-center justify-between px-6 py-4 max-w-7xl mx-auto">
    <div class="flex items-center gap-3">
      <div class="w-10 h-10 rounded-xl bg-gradient-to-br from-blue-500 to-purple-500 flex items-center justify-center">
        <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path>
        </svg>
      </div>
      <span class="text-xl font-bold">RAG Engine</span>
    </div>
    <div class="flex items-center gap-4">
      <a href="#features" class="text-gray-400 hover:text-white text-sm">Features</a>
      <a href="#use-cases" class="text-gray-400 hover:text-white text-sm">Casos</a>
      <a href="#pricing" class="text-gray-400 hover:text-white text-sm">Precios</a>
      <a href="#waitlist" class="px-5 py-2 rounded-full bg-white/5 hover:bg-white/10 border border-white/10 text-sm">
        Empezar
      </a>
    </div>
  </nav>

  <main class="relative z-10">
    <section class="px-6 py-20 max-w-7xl mx-auto">
      <div class="grid lg:grid-cols-2 gap-12 items-center">
        <div>
          <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-white/5 mb-6">
            <span class="w-2 h-2 rounded-full bg-green-400 animate-pulse"></span>
            <span class="text-sm text-gray-400">Ahora con embeddings ultra-rapidos</span>
          </div>
          
          <h1 class="text-5xl lg:text-6xl font-bold mb-6 leading-tight">
            Tu IA conoce
            <span class="text-transparent bg-clip-text bg-gradient-to-r from-blue-400 via-purple-400 to-cyan-400 block">tu negocio</span>
          </h1>
          
          <p class="text-lg text-gray-400 max-w-xl mb-8">
            Chatbot que sabe de tus productos, documentos y empresa.
            En minutos. Por API REST. Costos bajos.
          </p>

          <div class="flex gap-4 mb-10">
            <a href="#waitlist" class="px-8 py-4 rounded-full bg-gradient-to-r from-blue-500 to-purple-500 text-white font-semibold">
              Crear mi chatbot
            </a>
          </div>

          <div class="flex gap-8">
            <div>
              <div class="text-2xl font-bold" id="interested-count">99+</div>
              <div class="text-gray-500 text-sm">Empresas</div>
            </div>
            <div class="w-px bg-gray-700"></div>
            <div>
              <div class="text-2xl font-bold">$9</div>
              <div class="text-gray-500 text-sm">/mes starter</div>
            </div>
            <div class="w-px bg-gray-700"></div>
            <div>
              <div class="text-2xl font-bold">&lt;100ms</div>
              <div class="text-gray-500 text-sm">latencia</div>
            </div>
          </div>
        </div>

        <div class="bg-gray-800/50 rounded-2xl p-1 border border-gray-700">
          <div class="bg-gray-900 rounded-xl">
            <div class="px-5 py-4 border-b border-gray-700 flex items-center justify-between">
              <div class="flex items-center gap-3">
                <div class="w-10 h-10 rounded-full bg-gradient-to-br from-blue-500 to-purple-500 flex items-center justify-center">
                  <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 10h.01M12 10h.01M16 10h.01M9 16H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-5l-5 5v-5z"></path>
                  </svg>
                </div>
                <div>
                  <div class="font-medium">Asistente ZapatillasPro</div>
                  <div class="text-xs text-gray-500 flex items-center gap-1">
                    <span class="w-1.5 h-1.5 rounded-full bg-green-400"></span>
                    Online
                  </div>
                </div>
              </div>
              <div class="px-3 py-1 rounded-full bg-blue-500/10 text-blue-400 text-xs">
                E-commerce
              </div>
            </div>
            
            <div class="p-4 space-y-4 h-80 overflow-y-auto">
              <div class="flex gap-3">
                <div class="w-8 h-8 rounded-full bg-gradient-to-br from-blue-500 to-purple-500 flex-shrink-0"></div>
                <div class="bg-gray-800 rounded-xl px-4 py-3 max-w-[85%]">
                  <p class="text-sm">Hola. Soy el asistente de ZapatillasPro. En que puedo ayudarte?</p>
                </div>
              </div>

              <div class="flex justify-end">
                <div class="bg-gradient-to-r from-blue-500 to-purple-500 rounded-xl px-4 py-3 max-w-[85%]">
                  <p class="text-sm text-white">Estas zapatillas son resistentes al agua?</p>
                </div>
              </div>

              <div class="flex gap-3">
                <div class="w-8 h-8 rounded-full bg-gradient-to-br from-blue-500 to-purple-500 flex-shrink-0"></div>
                <div class="bg-gray-800 rounded-xl px-4 py-3 max-w-[85%]">
                  <p class="text-sm">Buena pregunta. Las Nike Air Max tienen mesh transpirable - no impermeable. No recomendadas para lluvia. Quieres ver modelos waterproof?</p>
                </div>
              </div>
            </div>

            <div class="p-4 border-t border-gray-700">
              <div class="flex gap-3">
                <input 
                  type="text" 
                  placeholder="Escribe tu pregunta..."
                  class="flex-1 px-4 py-3 rounded-xl bg-gray-800 border border-gray-700 focus:border-blue-500 focus:outline-none"
                />
                <button class="px-4 py-3 rounded-xl bg-gradient-to-r from-blue-500 to-purple-500 text-white">
                  <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8"></path>
                  </svg>
                </button>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section id="use-cases" class="px-6 py-20 bg-gray-800/30">
      <div class="max-w-7xl mx-auto">
        <div class="text-center mb-12">
          <h2 class="text-4xl font-bold mb-4">
            Un proyecto. <span class="text-transparent bg-clip-text bg-gradient-to-r from-blue-400 to-purple-400">Un mundo de posibilidades.</span>
          </h2>
        </div>

        <div class="grid md:grid-cols-3 gap-6">
          <div class="bg-gray-800/50 rounded-2xl p-8 border border-gray-700">
            <div class="w-14 h-14 rounded-2xl bg-amber-500/20 flex items-center justify-center mb-6">
              <svg class="w-7 h-7 text-amber-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z"></path>
              </svg>
            </div>
            <h3 class="text-xl font-semibold mb-3">E-commerce</h3>
            <p class="text-gray-400 mb-4">
              Tu chatbot sabe todos tus productos, precios, tallas. Responde "tiene en talla 42?", "vienen con garantia?".
            </p>
          </div>

          <div class="bg-gray-800/50 rounded-2xl p-8 border border-gray-700">
            <div class="w-14 h-14 rounded-2xl bg-purple-500/20 flex items-center justify-center mb-6">
              <svg class="w-7 h-7 text-purple-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path>
              </svg>
            </div>
            <h3 class="text-xl font-semibold mb-3">Legal</h3>
            <p class="text-gray-400 mb-4">
              Contratos, terminos, politicas. Tu IA responde "que dice la clausula 4?", "cual es la politica de devolucion?".
            </p>
          </div>

          <div class="bg-gray-800/50 rounded-2xl p-8 border border-gray-700">
            <div class="w-14 h-14 rounded-2xl bg-green-500/20 flex items-center justify-center mb-6">
              <svg class="w-7 h-7 text-green-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"></path>
              </svg>
            </div>
            <h3 class="text-xl font-semibold mb-3">Empresa</h3>
            <p class="text-gray-400 mb-4">
              Conoce tu empresa, servicios, horarios. "Cuales son los horarios?", "tienen servicio tecnico?".
            </p>
          </div>
        </div>
      </div>
    </section>

    <section id="features" class="px-6 py-20 max-w-7xl mx-auto">
      <div class="text-center mb-12">
        <h2 class="text-4xl font-bold mb-4">Todo lo que necesitas.</h2>
      </div>

      <div class="grid md:grid-cols-3 gap-6">
        <div class="bg-gray-800/50 rounded-xl p-6 border border-gray-700">
          <h3 class="font-semibold mb-2">Multi-fuente</h3>
          <p class="text-sm text-gray-400">PDFs, URLs, texto, APIs.</p>
        </div>
        <div class="bg-gray-800/50 rounded-xl p-6 border border-gray-700">
          <h3 class="font-semibold mb-2">Embeddings</h3>
          <p class="text-sm text-gray-400">Busqueda semantica.</p>
        </div>
        <div class="bg-gray-800/50 rounded-xl p-6 border border-gray-700">
          <h3 class="font-semibold mb-2">Aislamiento</h3>
          <p class="text-sm text-gray-400">Datos aislados por proyecto.</p>
        </div>
      </div>
    </section>

    <section id="pricing" class="px-6 py-20 bg-gray-800/30">
      <div class="max-w-7xl mx-auto">
        <div class="text-center mb-12">
          <h2 class="text-4xl font-bold mb-4">Precios que funcionan</h2>
          <p class="text-gray-400">Desde $9/mes.</p>
        </div>

        <div class="grid md:grid-cols-3 gap-6 max-w-5xl mx-auto">
          <div class="bg-gray-800/50 rounded-2xl p-8 border border-gray-700">
            <h3 class="text-xl font-semibold mb-2">Starter</h3>
            <div class="mb-6"><span class="text-4xl font-bold">$9</span><span class="text-gray-500">/mes</span></div>
            <ul class="space-y-3 mb-8 text-sm">
              <li class="flex items-center gap-2 text-gray-400">1 proyecto</li>
              <li class="flex items-center gap-2 text-gray-400">1,000 msgs/mes</li>
            </ul>
            <a href="#waitlist" class="block text-center px-6 py-3 rounded-full border border-gray-600">Empezar</a>
          </div>

          <div class="bg-gray-800/50 rounded-2xl p-8 border border-blue-500/30 relative">
            <div class="absolute -top-3 left-1/2 -translate-x-1/2 px-4 py-1 bg-gradient-to-r from-blue-500 to-purple-500 rounded-full text-sm">Popular</div>
            <h3 class="text-xl font-semibold mb-2">Pro</h3>
            <div class="mb-6"><span class="text-4xl font-bold">$29</span><span class="text-gray-500">/mes</span></div>
            <ul class="space-y-3 mb-8 text-sm">
              <li class="flex items-center gap-2 text-gray-400">5 proyectos</li>
              <li class="flex items-center gap-2 text-gray-400">10,000 msgs/mes</li>
            </ul>
            <a href="#waitlist" class="block text-center px-6 py-3 rounded-full bg-gradient-to-r from-blue-500 to-purple-500 text-white">Empezar</a>
          </div>

          <div class="bg-gray-800/50 rounded-2xl p-8 border border-gray-700">
            <h3 class="text-xl font-semibold mb-2">Business</h3>
            <div class="mb-6"><span class="text-4xl font-bold">$99</span><span class="text-gray-500">/mes</span></div>
            <ul class="space-y-3 mb-8 text-sm">
              <li class="flex items-center gap-2 text-gray-400">Proyectos ilimitados</li>
              <li class="flex items-center gap-2 text-gray-400">100,000 msgs/mes</li>
            </ul>
            <a href="#waitlist" class="block text-center px-6 py-3 rounded-full border border-gray-600">Contactar</a>
          </div>
        </div>
      </div>
    </section>

    <section id="waitlist" class="px-6 py-24 max-w-4xl mx-auto">
      <div class="bg-gray-800/50 rounded-3xl p-12 text-center border border-gray-700">
        <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-blue-500/10 text-blue-400 text-sm mb-8">
          Lanzamiento Q1 2026
        </div>

        <h2 class="text-5xl font-bold mb-4">Listo para empezar?</h2>
        
        <p class="text-gray-400 text-lg mb-10 max-w-lg mx-auto">
          Los primeros 100 get free lifetime access.
        </p>

        <form id="waitlist-form" class="flex flex-col sm:flex-row gap-4 max-w-md mx-auto">
          <input 
            type="email" 
            name="email"
            placeholder="tu@email.com" 
            required
            class="flex-1 px-6 py-4 rounded-full bg-gray-900 border border-gray-700 focus:border-blue-500 focus:outline-none text-lg"
          />
          <button 
            type="submit"
            class="px-8 py-4 rounded-full bg-gradient-to-r from-blue-500 to-purple-500 text-white font-semibold text-lg"
          >
            Unirse Gratis
          </button>
        </form>

        <div id="form-message" class="mt-6 text-sm hidden"></div>
      </div>
    </section>

    <footer class="px-6 py-12 border-t border-gray-800">
      <div class="max-w-7xl mx-auto flex flex-col md:flex-row items-center justify-between gap-6">
        <div class="flex items-center gap-3">
          <div class="w-8 h-8 rounded-lg bg-gradient-to-br from-blue-500 to-purple-500 flex items-center justify-center">
            <svg class="w-4 h-4 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path>
            </svg>
          </div>
          <span class="font-semibold">RAG Engine</span>
        </div>
        
        <div class="flex items-center gap-6 text-gray-400 text-sm">
          <a href="#" class="hover:text-white">Twitter</a>
          <a href="#" class="hover:text-white">GitHub</a>
        </div>

        <div class="text-gray-500 text-sm">2026 RAG Engine.</div>
      </div>
    </footer>
  </main>

  <script>
    var form = document.getElementById('waitlist-form');
    var messageEl = document.getElementById('form-message');
    var interestedCountEl = document.getElementById('interested-count');

    fetch('/api/waitlist').then(function(res) { return res.json(); }).then(function(data) {
      if (interestedCountEl && data.count) {
        interestedCountEl.textContent = data.count + '+';
      }
    });

    form.addEventListener('submit', function(e) {
      e.preventDefault();
      var formData = new FormData(form);
      var email = formData.get('email');
      var submitBtn = form.querySelector('button[type="submit"]');

      submitBtn.disabled = true;
      submitBtn.textContent = 'Enviando...';

      fetch('/api/waitlist', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ email: email })
      }).then(function(res) { return res.json(); }).then(function(data) {
        if (messageEl) {
          if (data.message) {
            messageEl.textContent = data.message;
            messageEl.className = 'mt-6 text-sm text-green-400';
          } else {
            messageEl.textContent = data.error || 'Error';
            messageEl.className = 'mt-6 text-sm text-red-400';
          }
          messageEl.classList.remove('hidden');
        }
        if (data.message) {
          form.reset();
        }
      }).finally(function() {
        submitBtn.disabled = false;
        submitBtn.textContent = 'Unirse Gratis';
      });
    });
  </script>
</Layout>
