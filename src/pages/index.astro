---
import Layout from "../layouts/Layout.astro";
---

<Layout title="youbase.ai - Motor de IA con conocimiento propio">

  <!-- Ambient glow — top center only -->
  <div
    class="fixed top-0 left-1/2 -translate-x-1/2 w-200 h-125 pointer-events-none"
    style="background: radial-gradient(ellipse at 50% 0%, rgba(219,162,122,0.13) 0%, transparent 65%); z-index: 0;"
  ></div>
  <!-- Very faint grid -->
  <div class="fixed inset-0 bg-grid-pattern pointer-events-none opacity-100"></div>

  <!-- ===== NAV ===== -->
  <nav id="main-nav" class="fixed top-0 left-0 right-0 z-50 nav-blur">
    <div class="flex items-center justify-between px-6 py-4 max-w-6xl mx-auto">
      <a href="#" class="flex items-center gap-2.5">
        <img src="/logo-h.png" alt="youbase.ai" class="h-20" />
      </a>

      <div class="hidden md:flex items-center gap-8">
        <a href="#how-it-works" class="text-sm text-[#6e6e73] hover:text-[#f5f5f7] transition-colors">Como funciona</a>
        <a href="#use-cases"    class="text-sm text-[#6e6e73] hover:text-[#f5f5f7] transition-colors">Casos</a>
        <a href="#features"     class="text-sm text-[#6e6e73] hover:text-[#f5f5f7] transition-colors">Features</a>
        <a href="#pricing"      class="text-sm text-[#6e6e73] hover:text-[#f5f5f7] transition-colors">Precios</a>
        <a href="#waitlist"     class="text-sm px-5 py-2 rounded-full border border-[#DBA27A]/35 text-[#DBA27A] hover:bg-[#DBA27A]/5 transition-all font-medium">
          Empezar gratis
        </a>
      </div>

      <button id="mobile-toggle" class="md:hidden p-2 text-[#6e6e73] hover:text-white" aria-label="Menu">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path id="hamburger-icon" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
        </svg>
      </button>
    </div>
  </nav>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="mobile-menu fixed inset-y-0 right-0 z-50 w-72 bg-[#060606]/98 backdrop-blur-xl border-l border-white/5 p-8 flex flex-col gap-6 md:hidden">
    <button id="mobile-close" class="self-end p-2 text-[#6e6e73] hover:text-white" aria-label="Cerrar">
      <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
      </svg>
    </button>
    <a href="#how-it-works" class="text-lg text-[#a1a1aa] hover:text-white mobile-link">Como funciona</a>
    <a href="#use-cases"    class="text-lg text-[#a1a1aa] hover:text-white mobile-link">Casos de uso</a>
    <a href="#features"     class="text-lg text-[#a1a1aa] hover:text-white mobile-link">Features</a>
    <a href="#pricing"      class="text-lg text-[#a1a1aa] hover:text-white mobile-link">Precios</a>
    <a href="#waitlist"     class="glow-button px-6 py-3 rounded-full text-center font-medium mobile-link">
      <span>Empezar gratis</span>
    </a>
  </div>

  <main class="relative z-10">

    <!-- ===== HERO ===== -->
    <section class="relative pt-40 pb-28 lg:pt-52 lg:pb-36 px-6 text-center">
      <div class="max-w-4xl mx-auto">

        <!-- Eyebrow -->
        <div class="reveal inline-flex items-center gap-2 mb-10">
          <span class="w-1.5 h-1.5 rounded-full bg-[#DBA27A] animate-pulse"></span>
          <span class="text-sm text-[#6e6e73] tracking-wide">Motor de IA listo para produccion</span>
        </div>

        <!-- Headline -->
        <h1
          class="reveal reveal-delay-1 font-bold leading-[1.05] tracking-[-0.04em] mb-8"
          style="font-size: clamp(2.6rem, 7vw, 5.5rem); font-family: var(--font-display);"
        >
          Conecta tu conocimiento<br>
          <span style="color: #DBA27A;">con inteligencia artificial.</span>
        </h1>

        <!-- Subtitle -->
        <p class="reveal reveal-delay-2 text-xl text-[#6e6e73] max-w-2xl mx-auto mb-12 leading-relaxed">
          IA que entiende tus documentos, productos y datos.
          Chatbots, buscadores y copilots via API en minutos.
        </p>

        <!-- CTAs -->
        <div class="reveal reveal-delay-3 flex flex-col sm:flex-row items-center justify-center gap-4 mb-24">
          <a href="#waitlist" class="glow-button px-8 py-3.5 rounded-full font-semibold text-base">
            <span>Empezar gratis</span>
          </a>
          <a href="#how-it-works" class="group flex items-center gap-2 text-[#6e6e73] hover:text-[#f5f5f7] transition-colors text-base">
            Ver como funciona
            <svg class="w-4 h-4 group-hover:translate-x-0.5 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"/>
            </svg>
          </a>
        </div>

        <!-- Stats -->
        <div class="reveal flex items-center justify-center gap-8 sm:gap-16 mb-24">
          <div class="text-center">
            <div class="stat-number text-4xl font-bold text-[#f5f5f7] mb-1" id="interested-count">99+</div>
            <div class="text-sm text-[#6e6e73]">empresas interesadas</div>
          </div>
          <div class="w-px h-10 bg-white/8"></div>
          <div class="text-center">
            <div class="stat-number text-4xl font-bold text-[#f5f5f7] mb-1">$9</div>
            <div class="text-sm text-[#6e6e73]">por mes desde</div>
          </div>
          <div class="w-px h-10 bg-white/8"></div>
          <div class="text-center">
            <div class="stat-number text-4xl font-bold text-[#f5f5f7] mb-1">&lt;100<span class="text-xl text-[#6e6e73]">ms</span></div>
            <div class="text-sm text-[#6e6e73]">latencia promedio</div>
          </div>
        </div>

        <!-- Chat demo -->
        <div class="reveal reveal-delay-2 relative max-w-xl mx-auto">
          <p class="text-xs text-[#9BB1B1] uppercase tracking-[0.15em] mb-5">Ejemplo · chatbot e-commerce</p>
          <div class="absolute -inset-6 rounded-3xl blur-3xl pointer-events-none" style="background: radial-gradient(ellipse, rgba(219,162,122,0.15) 0%, transparent 70%);"></div>
          <div class="relative rounded-2xl overflow-hidden" style="background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.08);">

            <!-- Header -->
            <div class="px-6 py-5 flex items-center justify-between" style="border-bottom: 1px solid rgba(255,255,255,0.06);">
              <div class="flex items-center gap-4">
                <div class="w-12 h-12 rounded-xl flex items-center justify-center shrink-0" style="background: linear-gradient(135deg, #DBA27A, #E5C695);">
                  <span class="text-base font-bold" style="color: #1a1a1a;">base</span>
                </div>
                <div>
                  <div class="text-base font-medium text-[#f5f5f7]">Asistente ZapatillasPro</div>
                  <div class="text-sm flex items-center gap-1.5 mt-0.5" style="color: #9BB1B1;">
                    <span class="w-2 h-2 rounded-full animate-pulse" style="background: #DBA27A;"></span>
                    Online · &lt;2s respuesta
                  </div>
                </div>
              </div>
              <span class="text-sm px-4 py-1.5 rounded-full" style="background: rgba(219,162,122,0.15); color: #DBA27A;">E-commerce</span>
            </div>

            <!-- Messages -->
            <div class="p-6 space-y-5 h-64 overflow-hidden">
              <div class="flex gap-4">
                <div class="w-10 h-10 rounded-xl flex items-center justify-center shrink-0" style="background: linear-gradient(135deg, #DBA27A, #E5C695);">
                  <span class="text-sm font-bold" style="color: #1a1a1a;">b</span>
                </div>
                <div class="px-5 py-4 rounded-2xl rounded-tl-sm max-w-[85%] text-base leading-relaxed" style="background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.08); color: #f5f5f7;">
                  Hola! Soy el asistente de <strong>ZapatillasPro</strong>. ¿En qué puedo ayudarte?
                </div>
              </div>
              <div class="flex justify-end">
                <div class="px-5 py-4 rounded-2xl rounded-tr-sm max-w-[85%] text-base" style="background: linear-gradient(135deg, #DBA27A, #E5C695); color: #1a1a1a;">
                  ¿Tiene este modelo en talla 42?
                </div>
              </div>
              <div class="flex gap-4">
                <div class="w-10 h-10 rounded-xl flex items-center justify-center shrink-0" style="background: linear-gradient(135deg, #DBA27A, #E5C695);">
                  <span class="text-sm font-bold" style="color: #1a1a1a;">b</span>
                </div>
                <div class="px-5 py-4 rounded-2xl rounded-tl-sm max-w-[85%] text-base leading-relaxed" style="background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.08); color: #f5f5f7;">
                  Sí! El <strong>Airmax Runner</strong> tiene stock en talles 40, 41 y 42. ¿Querés que te reserve uno?
                  <div class="flex gap-3 mt-4">
                    <span class="px-4 py-2 rounded-full text-sm cursor-pointer transition-colors" style="background: rgba(219,162,122,0.2); color: #DBA27A;">
                      Sí, reservar
                    </span>
                    <span class="px-4 py-2 rounded-full text-sm cursor-pointer transition-colors" style="background: rgba(255,255,255,0.05); color: #9BB1B1;">
                      Ver otros talles
                    </span>
                  </div>
                </div>
              </div>
              <div id="typing-indicator" class="flex gap-4 opacity-0 transition-opacity duration-500">
                <div class="w-10 h-10 rounded-xl flex items-center justify-center shrink-0" style="background: linear-gradient(135deg, #DBA27A, #E5C695);">
                  <span class="text-sm font-bold" style="color: #1a1a1a;">b</span>
                </div>
                <div class="px-5 py-4 rounded-2xl rounded-tl-sm" style="background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.08);">
                  <div class="animate-typing"><span></span><span></span><span></span></div>
                </div>
              </div>
            </div>

            <!-- Input -->
            <div class="p-5" style="border-top: 1px solid rgba(255,255,255,0.06);">
              <div class="flex gap-3">
                <input
                  type="text"
                  placeholder="Escribe tu pregunta..."
                  class="flex-1 px-5 py-4 rounded-xl text-base transition-colors outline-none"
                  style="background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.1); color: #f5f5f7;"
                  disabled
                />
                <button class="px-5 py-4 rounded-xl transition-all" style="background: linear-gradient(135deg, #DBA27A, #E5C695); color: #1a1a1a;" disabled>
                  <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 10h10a8 8 0 018 8v2M3 10l6 6m-6-6l6-6"/>
                  </svg>
                </button>
              </div>
            </div>

          </div>
        </div>
      </div>
    </section>

    <div class="section-divider"></div>

    <!-- ===== HOW IT WORKS ===== -->
    <section id="how-it-works" class="px-6 py-32 max-w-6xl mx-auto">
      <div class="text-center mb-20">
        <p class="reveal section-label">Simple de usar</p>
        <h2 class="reveal text-4xl lg:text-5xl font-bold tracking-[-0.03em] mt-4">Tres pasos. Listo.</h2>
      </div>

      <div class="grid md:grid-cols-3 gap-5 mb-14">
        <!-- Step 1 -->
        <div class="reveal clean-card rounded-2xl p-8">
          <div class="text-xs font-mono text-[#6e6e73] mb-6">01</div>
          <div class="w-11 h-11 rounded-xl bg-[#DBA27A]/10 flex items-center justify-center mb-6">
            <svg class="w-5 h-5 text-[#DBA27A]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-8l-4-4m0 0L8 8m4-4v12"/>
            </svg>
          </div>
          <h3 class="text-lg font-semibold mb-3">Subi tus datos</h3>
          <p class="text-sm text-[#6e6e73] leading-relaxed">PDFs, URLs, texto plano o conecta tu API. El sistema procesa e indexa todo automaticamente.</p>
        </div>

        <!-- Step 2 -->
        <div class="reveal reveal-delay-1 clean-card rounded-2xl p-8">
          <div class="text-xs font-mono text-[#6e6e73] mb-6">02</div>
          <div class="w-11 h-11 rounded-xl bg-[#DBA27A]/10 flex items-center justify-center mb-6">
            <svg class="w-5 h-5 text-[#DBA27A]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.066 2.573c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.573 1.066c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.066-2.573c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
            </svg>
          </div>
          <h3 class="text-lg font-semibold mb-3">Configura tu proyecto</h3>
          <p class="text-sm text-[#6e6e73] leading-relaxed">Elige modelo de IA, parametros de busqueda y formato de respuesta. Todo via dashboard o API.</p>
        </div>

        <!-- Step 3 -->
        <div class="reveal reveal-delay-2 clean-card rounded-2xl p-8">
          <div class="text-xs font-mono text-[#6e6e73] mb-6">03</div>
          <div class="w-11 h-11 rounded-xl bg-[#DBA27A]/10 flex items-center justify-center mb-6">
            <svg class="w-5 h-5 text-[#DBA27A]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/>
            </svg>
          </div>
          <h3 class="text-lg font-semibold mb-3">Consulta via API</h3>
          <p class="text-sm text-[#6e6e73] leading-relaxed">Respuestas inteligentes con contexto real de tus datos. Chatbot, buscador, copilot — lo que necesites.</p>
        </div>
      </div>

      <!-- Code snippet -->
      <div class="reveal max-w-2xl mx-auto">
        <div class="code-block rounded-xl overflow-hidden">
          <div class="flex items-center gap-2 px-4 py-3 border-b border-white/5">
            <div class="w-2.5 h-2.5 rounded-full bg-white/10"></div>
            <div class="w-2.5 h-2.5 rounded-full bg-white/10"></div>
            <div class="w-2.5 h-2.5 rounded-full bg-white/10"></div>
            <span class="ml-2 text-xs text-[#6e6e73] font-mono">query.sh</span>
          </div>
          <pre class="p-6 text-sm font-mono leading-loose overflow-x-auto scrollbar-thin"><code><span class="text-[#6e6e73]"># Una sola llamada para consultar tus datos</span>
<span class="text-[#DBA27A]">curl</span> <span class="text-[#a1a1aa]">-X POST</span> <span class="text-emerald-400">https://api.youbase.ai/v1/chat</span> \
  <span class="text-[#a1a1aa]">-H</span> <span class="text-amber-300">"Authorization: Bearer tu_api_key"</span> \
  <span class="text-[#a1a1aa]">-d</span> <span class="text-amber-300">'{{"message": "tienen talle 42?"}}'</span></code></pre>
        </div>
      </div>
    </section>

    <div class="section-divider"></div>

    <!-- ===== INGESTION API ===== -->
    <section id="ingestion" class="px-6 py-32 max-w-6xl mx-auto">
      <div class="grid lg:grid-cols-2 gap-16 items-center">

        <!-- Left: copy -->
        <div>
          <p class="reveal section-label mb-4">Ingestion API</p>
          <h2 class="reveal text-4xl lg:text-5xl font-bold tracking-[-0.03em] mt-0 mb-6">
            Dale conocimiento<br>a tu youbase.
          </h2>
          <p class="reveal text-[#6e6e73] text-lg leading-relaxed mb-10">
            Enviá documentos, URLs o texto plano via API y tu proyecto los procesa, fragmenta e indexa automaticamente.
            Sin configurar pipelines ni modelos de embedding.
          </p>

          <!-- Source types -->
          <div class="reveal space-y-3">
            <div class="flex items-center gap-3 p-4 clean-card rounded-xl">
              <div class="w-9 h-9 rounded-lg bg-[#DBA27A]/10 flex items-center justify-center shrink-0">
                <svg class="w-4 h-4 text-[#DBA27A]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
                </svg>
              </div>
              <div>
                <div class="text-sm font-medium text-[#f5f5f7]">Documentos</div>
                <div class="text-xs text-[#6e6e73]">PDF, DOCX, TXT, CSV, Markdown</div>
              </div>
            </div>
            <div class="flex items-center gap-3 p-4 clean-card rounded-xl">
              <div class="w-9 h-9 rounded-lg bg-purple-500/10 flex items-center justify-center shrink-0">
                <svg class="w-4 h-4 text-purple-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1"/>
                </svg>
              </div>
              <div>
                <div class="text-sm font-medium text-[#f5f5f7]">URLs & Sitemaps</div>
                <div class="text-xs text-[#6e6e73]">Paginas web, documentacion, blogs</div>
              </div>
            </div>
            <div class="flex items-center gap-3 p-4 clean-card rounded-xl">
              <div class="w-9 h-9 rounded-lg bg-amber-500/10 flex items-center justify-center shrink-0">
                <svg class="w-4 h-4 text-amber-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4"/>
                </svg>
              </div>
              <div>
                <div class="text-sm font-medium text-[#f5f5f7]">Raw Text & JSON</div>
                <div class="text-xs text-[#6e6e73]">Cualquier contenido estructurado o libre</div>
              </div>
            </div>
          </div>
        </div>

        <!-- Right: code tabs -->
        <div class="reveal reveal-delay-1">
          <!-- Tab selector -->
          <div class="flex gap-1 mb-4 p-1 rounded-xl bg-white/3 border border-white/6 w-fit">
            <button onclick="switchTab('pdf')"   id="tab-pdf"  class="ingestion-tab active-tab px-4 py-1.5 rounded-lg text-xs font-medium transition-all">PDF</button>
            <button onclick="switchTab('url')"   id="tab-url"  class="ingestion-tab px-4 py-1.5 rounded-lg text-xs font-medium transition-all text-[#6e6e73] hover:text-white">URL</button>
            <button onclick="switchTab('text')"  id="tab-text" class="ingestion-tab px-4 py-1.5 rounded-lg text-xs font-medium transition-all text-[#6e6e73] hover:text-white">Texto</button>
          </div>

          <!-- PDF -->
          <div id="snippet-pdf" class="ingestion-snippet">
            <div class="code-block rounded-xl overflow-hidden">
              <div class="flex items-center gap-2 px-4 py-3 border-b border-white/5">
                <div class="w-2.5 h-2.5 rounded-full bg-white/10"></div>
                <div class="w-2.5 h-2.5 rounded-full bg-white/10"></div>
                <div class="w-2.5 h-2.5 rounded-full bg-white/10"></div>
                <span class="ml-2 text-xs text-[#6e6e73] font-mono">ingest-pdf.sh</span>
              </div>
              <pre class="p-6 text-sm font-mono leading-loose overflow-x-auto scrollbar-thin"><code><span class="text-[#6e6e73]"># Subir un PDF a tu proyecto</span>
<span class="text-[#DBA27A]">curl</span> <span class="text-[#a1a1aa]">-X POST</span> <span class="text-emerald-400">https://api.youbase.ai/v1/ingest</span> \
  <span class="text-[#a1a1aa]">-H</span> <span class="text-amber-300">"Authorization: Bearer tu_api_key"</span> \
  <span class="text-[#a1a1aa]">-F</span> <span class="text-amber-300">"file=@catalogo-productos.pdf"</span> \
  <span class="text-[#a1a1aa]">-F</span> <span class="text-amber-300">"project_id=mi-ecommerce"</span>

<span class="text-[#6e6e73]"># Respuesta</span>
<span class="text-white">{</span>
  <span class="text-[#DBA27A]">"status"</span><span class="text-white">:</span> <span class="text-amber-300">"processing"</span><span class="text-white">,</span>
  <span class="text-[#DBA27A]">"chunks"</span><span class="text-white">:</span> <span class="text-purple-400">247</span><span class="text-white">,</span>
  <span class="text-[#DBA27A]">"message"</span><span class="text-white">:</span> <span class="text-amber-300">"Documento indexado correctamente"</span>
<span class="text-white">}</span></code></pre>
            </div>
          </div>

          <!-- URL -->
          <div id="snippet-url" class="ingestion-snippet hidden">
            <div class="code-block rounded-xl overflow-hidden">
              <div class="flex items-center gap-2 px-4 py-3 border-b border-white/5">
                <div class="w-2.5 h-2.5 rounded-full bg-white/10"></div>
                <div class="w-2.5 h-2.5 rounded-full bg-white/10"></div>
                <div class="w-2.5 h-2.5 rounded-full bg-white/10"></div>
                <span class="ml-2 text-xs text-[#6e6e73] font-mono">ingest-url.sh</span>
              </div>
